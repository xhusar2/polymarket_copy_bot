# Run from repo root: ./run.sh   (creates .venv, installs deps, starts bot)
# Needs: sudo apt install python3.12-venv   if `python3 -m venv` fails
#
# Docker: copy .env from this file, then: docker compose up --build -d
# State file persists in volume trader_state at /data/copy_state.json (STATE_FILE set in compose).

# Wallet to copy (Polymarket proxy address from their profile)
COPY_TARGET_WALLET=0xYourLeaderWallet

# Your signer (MetaMask export or Polymarket-exported key). Never commit real keys.
PRIVATE_KEY=0x...

# 0 = EOA pays own gas | 1 = Magic/email proxy | 2 = browser wallet / Gnosis Safe proxy (most common)
POLYMARKET_SIGNATURE_TYPE=2

# Polymarket "funder" / proxy that holds USDC (profile dropdown address). Defaults to signer if unset.
# POLYMARKET_FUNDER=0xYourProxyWallet

# Size multiplier vs leader (1.0 = same proportional intent)
COPY_SCALE=0.1

# Market filter (substring match on title/slug/event/outcome). Default: weather / temperatures preset.
# COPY_MARKET_FILTER=all          # copy every market
# COPY_MARKET_FILTER=weather     # default if unset
# COPY_MARKET_FILTER=keywords    # requires COPY_MARKET_KEYWORDS=foo,bar
# Optional extra substrings when mode is weather:
# COPY_MARKET_KEYWORDS=lightning,hail

# Optional cap on BUY notional per mirrored trade (USDC)
# MAX_BUY_USD=25

# Before posting: CLOB /balance-allowance (6-decimal fixed). BUY checks USDC balance + allowance; SELL checks outcome balance (+ allowance if API returns it).
# SKIP_BALANCE_CHECK=1
# Stale conditional balance on SELL: try refreshing cache first (extra API call)
# REFRESH_BALANCE_BEFORE_SELL=1

POLL_INTERVAL_SEC=3
TRADE_POLL_LIMIT=100

# Set true to log intended orders without signing (no PRIVATE_KEY needed if you only want to test polling)
DRY_RUN=1

# Include both maker and taker fills for the leader (recommended)
# TAKER_ONLY=false is default when unset

DATA_API_USER_AGENT=PolymarketCopyTrader/1.0
